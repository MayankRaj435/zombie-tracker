generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String
  name                String?
  awsAccessKeyId      String?  // Encrypted
  awsSecretAccessKey  String?  // Encrypted
  awsRegion           String?
  awsConnected        Boolean  @default(false)
  awsConnectedAt       DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  idleInstances       IdleInstance[]
  orphanedVolumes     OrphanedVolume[]
  unattachedEips      UnattachedEIP[]
  securityGroupIssues SecurityGroupIssue[]
  dailyCosts          DailyCost[]
  
  remediationActions        RemediationAction[]
  scheduledActions          ScheduledAction[]
  rightSizingRecommendations RightSizingRecommendation[]
  alertConfigurations       AlertConfiguration[]
  alerts                    Alert[]
}

model RemediationAction {
  id           String   @id @default(cuid())
  resourceId   String
  resourceType String   // "instance", "volume", "eip"
  action       String   // "stop", "terminate", "delete", "release"
  status       String   // "pending", "success", "failed"
  error        String?
  executedAt   DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model ScheduledAction {
  id           String   @id @default(cuid())
  resourceId   String
  resourceType String
  action       String
  schedule     String   // Cron expression
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RightSizingRecommendation {
  id              String   @id @default(cuid())
  resourceId      String
  resourceType    String
  currentType     String
  recommendedType String
  currentCost     Float
  recommendedCost Float
  monthlySavings  Float
  reason          String
  confidence      String   // "high", "medium", "low"
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AlertConfiguration {
  id           String   @id @default(cuid())
  type         String   // "cost", "security", "utilization"
  threshold    Float?
  enabled      Boolean  @default(true)
  channels     String[] // ["email", "slack"]
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model Alert {
  id          String   @id @default(cuid())
  title       String
  message     String
  severity    String   // "critical", "high", "medium", "low"
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IdleInstance {
  id           String   @id @default(cuid())
  instanceId   String
  instanceType String?
  reason       String
  estimatedMonthlyCost String?  
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([instanceId, userId])
  @@index([userId])
}

model OrphanedVolume {
  id         String   @id @default(cuid())
  volumeId   String
  sizeGb     Int?
  volumeType String?
  reason     String
  estimatedMonthlyCost String?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([volumeId, userId])
  @@index([userId])
}

model UnattachedEIP {
  id           String   @id @default(cuid())
  publicIp     String?
  allocationId String
  reason       String
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([allocationId, userId])
  @@index([userId])
}

model SecurityGroupIssue {
  id          String   @id @default(cuid())
  groupId     String
  groupName   String?
  description String
  severity    String // "High", "Medium", "Low"
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId, description]) // Prevent duplicate alerts for the same issue
  @@index([userId])
}

/// Caches daily spend data fetched from AWS Cost Explorer.
/// Avoids repeated API calls (each call costs $0.01).
/// `service` is optional — null means the total across all services.
model DailyCost {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  amount    Float
  service   String?  // e.g. "AmazonEC2", null = account total
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, date, service])
  @@index([userId])
  @@index([userId, date])
}